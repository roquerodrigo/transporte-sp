---
/**
 * The provenance badge that follows a value everywhere it is shown.
 *
 * It is deliberately unmissable: the point of the project is that no number on the page is
 * anonymous, so the source travels with the value rather than living in a footnote.
 */
import { CONFIDENCE_LABELS, SOURCE_LABELS, type Confidence } from "@data/network";

interface Props {
  fonte: string;
  nivel: Confidence;
}

const { fonte, nivel } = Astro.props;
const label = SOURCE_LABELS[fonte] ?? fonte;
---

<span class="origem" data-nivel={nivel} title={`Fonte ${label} — ${CONFIDENCE_LABELS[nivel]}`}>
  <span class="origem-nivel">{nivel}</span>
  <span class="origem-fonte">{label}</span>
</span>

<style>
  /*
   * The chip is built from Starlight's own semantic colour pairs (`-low` for the surface,
   * `-high` for the text), which is the same mechanism the asides use. They are already
   * calibrated for contrast in both light and dark, so the badge follows whatever theme is
   * active instead of carrying two hard-coded hexes per level.
   */
  .origem {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    font-size: 0.75em;
    line-height: 1.4;
    white-space: nowrap;
    border-radius: 999px;
    padding: 0.1em 0.55em;
    background: var(--nivel-fundo);
    color: var(--nivel-texto);
    vertical-align: middle;
  }

  .origem-nivel {
    font-weight: 700;
  }

  .origem-nivel::after {
    content: "·";
    margin-inline-start: 0.35em;
    opacity: 0.6;
  }

  .origem[data-nivel="A"] {
    --nivel-fundo: var(--sl-color-green-low);
    --nivel-texto: var(--sl-color-green-high);
  }
  .origem[data-nivel="B"] {
    --nivel-fundo: var(--sl-color-blue-low);
    --nivel-texto: var(--sl-color-blue-high);
  }
  .origem[data-nivel="C"] {
    --nivel-fundo: var(--sl-color-orange-low);
    --nivel-texto: var(--sl-color-orange-high);
  }
  .origem[data-nivel="D"] {
    --nivel-fundo: var(--sl-color-red-low);
    --nivel-texto: var(--sl-color-red-high);
  }
  .origem[data-nivel="E"] {
    --nivel-fundo: var(--sl-color-purple-low);
    --nivel-texto: var(--sl-color-purple-high);
  }
</style>
