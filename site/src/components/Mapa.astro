---
/**
 * The map, in its three uses: the whole network, one line, one station.
 *
 * The basemap is CARTO's raster tiles rather than a vector style, because a vector style
 * needs either an API key or a self-hosted tile set — neither of which belongs in a static
 * site meant to be forkable. The network itself is drawn from the project's own GeoJSON.
 */
interface Props {
  /** Only draw this line, and frame the map on it. */
  linha?: string;
  /** Centre on this station and mark it. */
  estacao?: string;
  centro?: [number, number];
  zoom?: number;
  altura?: string;
  /** Show the projected network alongside the operating one. */
  futuro?: boolean;
}

const {
  linha,
  estacao,
  centro = [-46.633, -23.55],
  zoom = 10,
  altura = "26rem",
  futuro = true,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const dados = `${base}dados/network.geojson`;
const id = `mapa-${Math.random().toString(36).slice(2, 9)}`;
---

<div
  class="mapa"
  id={id}
  style={`height: ${altura}`}
  data-fonte={dados}
  data-base={base}
  data-linha={linha}
  data-estacao={estacao}
  data-centro={JSON.stringify(centro)}
  data-zoom={zoom}
  data-futuro={String(futuro)}
>
</div>

<noscript>
  <p>O mapa precisa de JavaScript. Os mesmos dados estão em <code>dados/network.geojson</code>.</p>
</noscript>

<script>
  import maplibregl from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";

  // The GeoJSON types are no longer ambient, so they are imported explicitly.
  import type { Feature, FeatureCollection, Geometry, Point } from "geojson";

  /** CARTO ships a light and a dark basemap; the map follows whichever theme is active. */
  const basemap = (dark: boolean) => {
    const variant = dark ? "dark_all" : "light_all";
    return {
      version: 8 as const,
      sources: {
        carto: {
          type: "raster" as const,
          tiles: ["a", "b"].map(
            (host) => `https://${host}.basemaps.cartocdn.com/${variant}/{z}/{x}/{y}@2x.png`,
          ),
          tileSize: 256,
          attribution:
            '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> · ' +
            '© <a href="https://carto.com/attributions">CARTO</a>',
        },
      },
      layers: [{ id: "carto", type: "raster" as const, source: "carto" }],
    };
  };

  const isDark = () =>
    (document.documentElement.dataset.theme ??
      (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")) === "dark";

  const DASHED = ["partial", "under_construction", "planned", "proposed"];

  const MODOS: Record<string, string> = {
    subway: "Metrô",
    monorail: "Monotrilho",
    commuter_rail: "Trem metropolitano",
    intercity_rail: "Trem intercidades",
    lrt: "VLT",
    people_mover: "Aeromóvel",
    brt: "BRT e corredores",
  };

  const ORDEM_MODOS = [
    "subway", "monorail", "commuter_rail", "intercity_rail", "lrt", "people_mover", "brt",
  ];

  /**
   * On a station's own map, only the modes it belongs to are drawn.
   *
   * That map is a couple of blocks wide and centred on one platform, where a bus corridor
   * or a light-rail line running past adds clutter and no information — the reader is
   * looking at a metro station, not at everything that happens to pass nearby.
   */
  const MODOS_SOBRE_TRILHOS = ["subway", "monorail", "commuter_rail", "intercity_rail"];

  /**
   * What the reader chose to hide, kept between visits.
   *
   * Only the modes that are *off* are stored: a mode added to the dataset later then shows
   * up by default instead of being silently hidden by a preference saved before it existed.
   * Storage can throw — private windows, disabled cookies — and a map that fails to draw
   * because it could not read a preference would be a poor trade.
   */
  const CHAVE_MODOS = "transporte-sp:modos-ocultos";

  const lerOcultos = (): Set<string> => {
    try {
      const bruto = localStorage.getItem(CHAVE_MODOS);
      return new Set(bruto ? (JSON.parse(bruto) as string[]) : []);
    } catch {
      return new Set();
    }
  };

  const gravarOcultos = (ocultos: Iterable<string>): void => {
    try {
      localStorage.setItem(CHAVE_MODOS, JSON.stringify([...ocultos]));
    } catch {
      /* preference not kept; the map still works */
    }
  };

  type NetworkFeature = Feature<Geometry, Record<string, any>>;

  function bounds(features: NetworkFeature[]): maplibregl.LngLatBounds | null {
    let box: maplibregl.LngLatBounds | null = null;
    const add = (position: number[]) => {
      const point = position as [number, number];
      box = box ? box.extend(point) : new maplibregl.LngLatBounds(point, point);
    };
    for (const feature of features) {
      const geometry = feature.geometry;
      if (geometry.type === "Point") add(geometry.coordinates);
      if (geometry.type === "MultiLineString") geometry.coordinates.flat().forEach(add);
      if (geometry.type === "LineString") geometry.coordinates.forEach(add);
    }
    return box;
  }

  /**
   * A checkbox per mode present in the data.
   *
   * Built as a MapLibre control rather than markup next to the map so it survives going
   * full screen — in full screen the map element is the only thing on the page, and
   * anything outside it disappears.
   */
  class ControleModos implements maplibregl.IControl {
    private readonly container = document.createElement("div");

    constructor(
      private readonly modos: string[],
      private readonly visiveis: Set<string>,
      private readonly aoMudar: (visiveis: Set<string>) => void,
    ) {}

    onAdd(): HTMLElement {
      this.container.className = "maplibregl-ctrl maplibregl-ctrl-group filtro-modos";
      this.container.innerHTML = `<p class="filtro-titulo">Exibir</p>`;

      for (const modo of this.modos) {
        const label = document.createElement("label");
        const caixa = document.createElement("input");
        caixa.type = "checkbox";
        caixa.checked = this.visiveis.has(modo);
        caixa.addEventListener("change", () => {
          caixa.checked ? this.visiveis.add(modo) : this.visiveis.delete(modo);
          gravarOcultos(this.modos.filter((item) => !this.visiveis.has(item)));
          this.aoMudar(this.visiveis);
        });
        label.append(caixa, document.createTextNode(MODOS[modo] ?? modo));
        this.container.append(label);
      }
      return this.container;
    }

    onRemove(): void {
      this.container.remove();
    }
  }

  async function draw(container: HTMLElement) {
    const { fonte, base, linha, estacao, centro, zoom, futuro } = container.dataset;
    const collection: FeatureCollection = await fetch(fonte!).then((r) => r.json());

    const modosDe = (feature: NetworkFeature): string[] =>
      feature.properties.kind === "line"
        ? [feature.properties.mode]
        : (feature.properties.modes ?? []);

    let features = collection.features as NetworkFeature[];
    if (futuro !== "true") {
      features = features.filter((feature) => feature.properties.status === "operational");
    }
    if (linha) {
      features = features.filter(
        (feature) =>
          feature.properties.id === linha || (feature.properties.lines ?? []).includes(linha),
      );
    }

    const focus = estacao
      ? features.find((feature) => feature.properties.id === estacao)
      : undefined;

    const modosDoFoco: string[] = focus?.properties.modes ?? [];
    if (modosDoFoco.some((modo) => MODOS_SOBRE_TRILHOS.includes(modo))) {
      features = features.filter((feature) =>
        modosDe(feature).some((modo) => MODOS_SOBRE_TRILHOS.includes(modo)),
      );
    }

    const map = new maplibregl.Map({
      container,
      style: basemap(isDark()),
      center: (((focus?.geometry as Point)?.coordinates ??
        JSON.parse(centro!)) as [number, number]),
      zoom: focus ? 15 : Number(zoom),
      attributionControl: { compact: true },
    });
    map.addControl(new maplibregl.NavigationControl({ showCompass: false }), "top-right");
    map.addControl(new maplibregl.FullscreenControl(), "top-right");

    // Only offer a filter where there is something to filter: a single line's map has one
    // mode, and a station's map is a couple of blocks wide — in both the control is noise.
    const modos = ORDEM_MODOS.filter((modo) =>
      features.some((feature) => modosDe(feature).includes(modo)),
    );
    // The stored preference belongs to the network map, which is the only one that offers
    // the control. A line's own map must show that line whatever the reader hid elsewhere.
    const comControle = !linha && !estacao && modos.length > 1;
    const ocultos = comControle ? lerOcultos() : new Set<string>();
    const visiveis = new Set(modos.filter((modo) => !ocultos.has(modo)));
    if (comControle) {
      map.addControl(new ControleModos(modos, visiveis, () => aplicarFiltro()), "top-left");
    }

    /**
     * Hide whole modes by filtering the layers, so nothing is re-fetched or rebuilt.
     *
     * A line carries one mode; a station carries the modes of every line serving it, so it
     * stays on the map while any of them is visible. There is no array-intersection
     * expression in MapLibre, hence the explicit `any` over the selected modes.
     */
    const aplicarFiltro = () => {
      const selecionados = modos.filter((modo) => visiveis.has(modo));
      if (map.getLayer("tracado")) {
        map.setFilter("tracado", [
          "all",
          ["==", ["get", "kind"], "line"],
          ["in", ["get", "mode"], ["literal", selecionados]],
        ]);
      }
      if (map.getLayer("estacoes")) {
        // Built dynamically, so the literal type does not line up with the spec union.
        const porModo = selecionados.map((modo) => ["in", modo, ["get", "modes"]]);
        map.setFilter("estacoes", [
          "all",
          ["==", ["get", "kind"], "station"],
          ["any", ...porModo],
        ] as unknown as maplibregl.FilterSpecification);
      }
    };

    // Swapping the style drops every custom layer, so they are added again on each change.
    new MutationObserver(() => {
      const wanted = basemap(isDark());
      if (JSON.stringify(map.getStyle().sources) !== JSON.stringify(wanted.sources)) {
        map.setStyle(wanted, { diff: false });
      }
    }).observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });

    // `style.load` fires again after every basemap swap, so the layers are re-added each
    // time while the framing and the event handlers are set up only once.
    let primeiraCarga = true;
    map.on("style.load", () => {
      map.addSource("rede", { type: "geojson", data: { type: "FeatureCollection", features } });

      map.addLayer({
        id: "tracado",
        type: "line",
        source: "rede",
        filter: ["==", ["get", "kind"], "line"],
        layout: { "line-cap": "round", "line-join": "round" },
        paint: {
          "line-color": ["coalesce", ["get", "colour"], "#6b7280"],
          "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1.8, 14, 5],
          "line-opacity": ["case", ["in", ["get", "status"], ["literal", DASHED]], 0.55, 0.95],
          "line-dasharray": [
            "case",
            ["in", ["get", "status"], ["literal", DASHED]],
            ["literal", [2, 1.6]],
            ["literal", [1, 0]],
          ],
        },
      });

      map.addLayer({
        id: "estacoes",
        type: "circle",
        source: "rede",
        filter: ["==", ["get", "kind"], "station"],
        paint: {
          "circle-radius": ["interpolate", ["linear"], ["zoom"], 9, 2.2, 15, 6],
          "circle-color": "#ffffff",
          "circle-stroke-width": ["case", ["get", "interchange"], 2.4, 1.4],
          "circle-stroke-color": "#111827",
        },
      });

      // Re-applied here because a basemap swap drops the layers and their filters with them.
      aplicarFiltro();

      if (focus) {
        map.addLayer({
          id: "foco",
          type: "circle",
          source: "rede",
          filter: ["==", ["get", "id"], estacao!],
          paint: {
            "circle-radius": 9,
            "circle-color": "#ef4444",
            "circle-opacity": 0.35,
            "circle-stroke-width": 2,
            "circle-stroke-color": "#ef4444",
          },
        });
      } else if (primeiraCarga) {
        const box = bounds(features);
        if (box) map.fitBounds(box, { padding: 32, maxZoom: 14, animate: false });
      }

      if (!primeiraCarga) return;
      primeiraCarga = false;

      /**
       * Where a feature's own page lives. Stations sit outside any line, so a station and a
       * line resolve differently; the base path comes from the element because this script
       * also runs on a page served under a different prefix by a fork.
       */
      const enderecoDe = (feature: NetworkFeature): string =>
        feature.properties.kind === "station"
          ? `${base}estacao/${feature.properties.slug}/`
          : `${base}linhas/${feature.properties.slug}/`;

      /** A station under the cursor wins over the line it sits on: it is the finer target. */
      const alvoDe = (features: NetworkFeature[] | undefined): NetworkFeature | undefined =>
        features?.find((item) => item.properties.kind === "station") ?? features?.[0];

      const popup = new maplibregl.Popup({
        closeButton: false,
        offset: 12,
        className: "mapa-popup",
      });

      map.on("mousemove", ["estacoes", "tracado"], (event) => {
        const feature = alvoDe(event.features as NetworkFeature[] | undefined);
        if (!feature) return;
        map.getCanvas().style.cursor = "pointer";

        const link = document.createElement("a");
        link.href = enderecoDe(feature);
        link.textContent = String(feature.properties.name);
        popup.setLngLat(event.lngLat).setDOMContent(link).addTo(map);
      });

      map.on("mouseleave", ["estacoes", "tracado"], () => {
        map.getCanvas().style.cursor = "";
        popup.remove();
      });

      // The popup is a hover hint and cannot be reached with the pointer, so the feature
      // itself is the link: clicking anywhere on a station or a line opens its page.
      map.on("click", ["estacoes", "tracado"], (event) => {
        const feature = alvoDe(event.features as NetworkFeature[] | undefined);
        if (feature) location.href = enderecoDe(feature);
      });
    });
  }

  document.querySelectorAll<HTMLElement>(".mapa").forEach(draw);
</script>

<style is:global>
  /* The mode filter is created by MapLibre at runtime, so it never receives the scope
     attribute Astro adds to markup in this file — these rules have to be global. */
  .filtro-modos {
    padding: 0.5rem 0.65rem;
    font-size: 0.78rem;
    line-height: 1.5;
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
    max-width: 12rem;
  }

  .filtro-modos .filtro-titulo {
    margin: 0 0 0.3rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }

  .filtro-modos label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
    white-space: nowrap;
  }

  .filtro-modos input {
    accent-color: var(--sl-color-accent);
    margin: 0;
  }

</style>

<style>
  /* In full screen the map covers the page, so the panel needs the page's own background
     rather than inheriting whatever sat behind it in the article. */
  .mapa:fullscreen {
    border-radius: 0;
    border: 0;
  }

  .mapa {
    width: 100%;
    border-radius: 0.5rem;
    overflow: hidden;
    margin-block: 1rem 1.5rem;
    background: var(--sl-color-gray-6);
  }
</style>
