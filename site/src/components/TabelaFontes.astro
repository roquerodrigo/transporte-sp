---
/** The sources that fed the current build, with the date of the snapshot actually used. */
import Nivel from "@components/Nivel.astro";
import { network } from "@data/network";
import { data } from "@data/formato";

const URLS: Record<string, string> = {
  geosampa: "https://geosampa.prefeitura.sp.gov.br/",
  gtfs_sptrans: "https://www.sptrans.com.br/desenvolvedores/",
  osm: "https://www.openstreetmap.org/copyright",
  wikidata: "https://query.wikidata.org/",
};
---

<table>
  <thead>
    <tr>
      <th>Fonte</th>
      <th>Licença</th>
      <th>Confiança</th>
      <th>Coleta usada</th>
    </tr>
  </thead>
  <tbody>
    {
      network.sources.map((source) => (
        <tr>
          <td>
            <a href={URLS[source.id] ?? "#"}>{source.name}</a>
          </td>
          <td>{source.licence}</td>
          <td>
            <Nivel nivel={source.confidence} />
          </td>
          <td>{data(source.fetched_at)}</td>
        </tr>
      ))
    }
  </tbody>
</table>
