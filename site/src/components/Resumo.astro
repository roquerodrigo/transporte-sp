---
/** Headline counts on the home page, read straight from the dataset. */
import { network } from "@data/network";
import { data, numero } from "@data/formato";

const rail = network.lines.filter((line) => line.mode.value !== "brt");
const running = rail.filter((line) => ["operational", "partial"].includes(line.status.value));
const planned = network.lines.filter((line) =>
  ["planned", "proposed", "under_construction"].includes(line.status.value),
);
const kilometres = running.reduce((total, line) => total + (line.length_km?.value ?? 0), 0);

const tiles = [
  { value: numero(running.length), label: "linhas em operação" },
  { value: numero(network.stations.length), label: "estações" },
  { value: `${numero(Math.round(kilometres))} km`, label: "de rede em operação" },
  { value: numero(planned.length), label: "linhas projetadas ou em obras" },
];
---

<div class="resumo">
  {
    tiles.map((tile) => (
      <div class="tile">
        <strong>{tile.value}</strong>
        <span>{tile.label}</span>
      </div>
    ))
  }
</div>

<p class="atualizado">
  Reconciliado em {data(network.generated_at)} a partir de {numero(network.sources.length)} fontes.
</p>

<style>
  .resumo {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: 1rem;
    margin-block: 2rem 0.5rem;
    /* These are cards with a background: a shorter label must not make one of them shorter
       than the rest of the row. */
    align-items: stretch;
  }

  /* Same reason as the summary card: Starlight's flow spacing reaches the grid cells and
     shortens every tile except the first. */
  .resumo .tile {
    margin: 0;
  }

  .tile {
    background: var(--sl-color-gray-7);
    border-radius: 0.5rem;
    padding: 1rem;
    text-align: center;
    /* Pin the number to the top of the card so the numbers line up across the row even
       when one label wraps to a second line. */
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .tile strong {
    display: block;
    font-size: 1.9rem;
    line-height: 1.1;
    color: var(--sl-color-white);
  }

  .tile span {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }

  .atualizado {
    text-align: center;
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }
</style>
