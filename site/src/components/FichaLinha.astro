---
/** Summary card at the top of a line's page. */
import Origem from "@components/Origem.astro";
import { numero, quilometros } from "@data/formato";
import {
  MODE_LABELS,
  STATUS_LABELS,
  lineById,
  lineColour,
  type Line,
  type Sourced,
} from "@data/network";

interface Props {
  linha: string;
}

const line = lineById(Astro.props.linha) as Line;

const entries: { label: string; value: string; field?: Sourced<unknown> | null }[] = [
  { label: "Modo", value: MODE_LABELS[line.mode.value] ?? line.mode.value, field: line.mode },
  {
    label: "Situação",
    value: STATUS_LABELS[line.status.value] ?? line.status.value,
    field: line.status,
  },
  { label: "Operadora", value: line.operator?.value ?? "—", field: line.operator },
  {
    label: "Extensão",
    value: line.length_km ? quilometros(line.length_km.value) : "—",
    field: line.length_km,
  },
  { label: "Estações", value: line.stations.length ? numero(line.stations.length) : "—" },
];

// Only where there is something planned: on a line with no extension the row would read
// as a missing value rather than as an absence of plans.
if (line.planned_length_km) {
  entries.push({
    label: "Projetado",
    value: `+ ${quilometros(line.planned_length_km.value)}`,
    field: line.planned_length_km,
  });
}
---

<div class="ficha" style={`--linha-cor: ${lineColour(line)}`}>
  <dl>
    {
      entries.map((entry) => (
        <div>
          <dt>{entry.label}</dt>
          <dd>
            {entry.value}
            {entry.field && <Origem fonte={entry.field.source} nivel={entry.field.confidence} />}
          </dd>
        </div>
      ))
    }
  </dl>
</div>

<style>
  .ficha {
    border-left: 0.35rem solid var(--linha-cor);
    background: var(--sl-color-gray-7);
    border-radius: 0.4rem;
    padding: 0.9rem 1.1rem;
    margin-block: 1rem 1.5rem;
  }

  dl {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 0.9rem 1.4rem;
    margin: 0;
    /* Stretch, not the default: without it the cells align to the bottom of their row, so
       a value that wraps pushes its own label up and the labels stop lining up. Stretching
       also gives every cell in a row the same height. */
    align-items: stretch;
  }

  /*
   * Starlight gives every element that follows a sibling a top margin, which reaches the
   * grid cells here: the first one kept its full height and every other lost a rem of it,
   * so the leading card was always taller than the rest of its row.
   */
  dl > div {
    margin: 0;
  }

  dt {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--sl-color-gray-3);
  }

  /*
   * The badge always sits on its own line. Letting it flow beside the value made the cell
   * one line for "Metrô" and three for "Projetada", so the card came out ragged and the
   * rows below it started at a different height on every page.
   */
  dd {
    /* Starlight indents `dd` by a rem, as a definition list should be — but this is a
       label-over-value card, not a definition list, and the indent left every value out of
       line with its own label. */
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.3rem;
    font-weight: 600;
  }
</style>
