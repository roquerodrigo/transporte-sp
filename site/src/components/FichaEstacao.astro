---
/** Summary card at the top of a station's page. */
import Origem from "@components/Origem.astro";
import { data } from "@data/formato";
import {
  ACCESSIBILITY_LABELS,
  STATUS_LABELS,
  stationById,
  type Sourced,
  type Station,
} from "@data/network";

interface Props {
  estacao: string;
}

const station = stationById(Astro.props.estacao) as Station;
const point = station.coordinates.value;

const entries: { label: string; value: string; field?: Sourced<unknown> | null }[] = [
  { label: "Sigla", value: station.code?.value ?? "—", field: station.code },
  {
    label: "Situação",
    value: STATUS_LABELS[station.status.value] ?? station.status.value,
    field: station.status,
  },
  {
    label: "Acessibilidade",
    value: station.accessibility
      ? (ACCESSIBILITY_LABELS[station.accessibility.value] ?? station.accessibility.value)
      : "Não informado",
    field: station.accessibility,
  },
  {
    label: "Inauguração",
    value: station.opened ? data(station.opened.value) : "—",
    field: station.opened,
  },
  {
    label: "Coordenada",
    value: `${point.lat.toFixed(5)}, ${point.lon.toFixed(5)}`,
    field: station.coordinates,
  },
  { label: "Baldeação", value: station.is_interchange ? "Sim" : "Não" },
];
---

<div class="ficha">
  <dl>
    {
      entries.map((entry) => (
        <div>
          <dt>{entry.label}</dt>
          <dd>
            {entry.value}
            {entry.field && <Origem fonte={entry.field.source} nivel={entry.field.confidence} />}
          </dd>
        </div>
      ))
    }
  </dl>
</div>

<style>
  .ficha {
    background: var(--sl-color-gray-7);
    border-radius: 0.4rem;
    padding: 0.9rem 1.1rem;
    margin-block: 1rem 1.5rem;
  }

  dl {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 0.9rem 1.4rem;
    margin: 0;
    /* Stretch, not the default: without it the cells align to the bottom of their row, so
       a value that wraps pushes its own label up and the labels stop lining up. Stretching
       also gives every cell in a row the same height. */
    align-items: stretch;
  }

  /*
   * Starlight gives every element that follows a sibling a top margin, which reaches the
   * grid cells here: the first one kept its full height and every other lost a rem of it,
   * so the leading card was always taller than the rest of its row.
   */
  dl > div {
    margin: 0;
  }

  dt {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--sl-color-gray-3);
  }

  /*
   * The badge always sits on its own line. Letting it flow beside the value made the cell
   * one line for "Metrô" and three for "Projetada", so the card came out ragged and the
   * rows below it started at a different height on every page.
   */
  dd {
    /* Starlight indents `dd` by a rem, as a definition list should be — but this is a
       label-over-value card, not a definition list, and the indent left every value out of
       line with its own label. */
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.3rem;
    font-weight: 600;
  }
</style>
