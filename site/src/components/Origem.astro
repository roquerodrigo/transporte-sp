---
/**
 * The provenance badge that follows a value everywhere it is shown: the confidence level
 * and the source that supplied it.
 *
 * It is deliberately unmissable — the point of the project is that no number on the page is
 * anonymous, so the source travels with the value rather than living in a footnote.
 */
import { CONFIDENCE_LABELS, SOURCE_LABELS, type Confidence } from "@data/network";

interface Props {
  fonte: string;
  nivel: Confidence;
}

const { fonte, nivel } = Astro.props;
const label = SOURCE_LABELS[fonte] ?? fonte;
---

<span class="pill" data-nivel={nivel} title={`Fonte ${label} — ${CONFIDENCE_LABELS[nivel]}`}>
  <span class="pill-separador">{nivel}</span>
  <span>{label}</span>
</span>
